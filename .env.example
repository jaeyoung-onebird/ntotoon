# Auth
NEXTAUTH_SECRET="change-this-to-random-string"
NEXTAUTH_URL="http://localhost:3002"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ntow"

# Redis
REDIS_URL="redis://localhost:6379"

# AI
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""

# AWS S3 (optional - uses local storage if not set)
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# Toss Payments (optional - uses test mode if not set)
# Get keys from https://developers.tosspayments.com
NEXT_PUBLIC_TOSS_CLIENT_KEY=""   # 클라이언트 키 (test_ck_... or live_ck_...)
TOSS_SECRET_KEY=""               # 시크릿 키 (test_sk_... or live_sk_...)

# Error Monitoring (optional)
# SENTRY_DSN=""

# Queue (optional - uses inline processing if not set)
# USE_QUEUE=true

# Config (all optional - defaults shown)
# MAX_PANELS=20
# PANEL_BATCH_SIZE=5
# WEBTOON_WIDTH=1080
# PANEL_GAP=30
# GEMINI_MODEL_CHEAP=gemini-2.5-flash-image
# GEMINI_MODEL_QUALITY=gemini-3.1-flash-image-preview
# QA_MODEL=claude-sonnet-4-6
# MAX_STYLE_REFS=3
# MAX_EVAL_PANELS=10
# QA_PASS_SCORE=9
# QA_MAX_RETRIES=3
# USD_TO_KRW=1370
# CREDIT_VALUE_KRW=100
# CREDIT_MARKUP=1.3
